# ============================================================
# Railway Environment Variables — Reference
# Set these in the Railway dashboard for each service.
# NEVER commit real secrets to git.
# ============================================================

# ── Shared across all services ───────────────────────────────
NODE_ENV=production
JWT_ACCESS_SECRET=<generate: openssl rand -hex 32>
JWT_REFRESH_SECRET=<generate: openssl rand -hex 32>
SERVICE_SECRET=<generate: openssl rand -hex 32>

# ── auth-service ─────────────────────────────────────────────
# (Railway PostgreSQL plugin auto-provides DB_* vars — reference them)
DB_HOST=${{Postgres_auth.PGHOST}}
DB_PORT=${{Postgres_auth.PGPORT}}
DB_NAME=${{Postgres_auth.PGDATABASE}}
DB_USER=${{Postgres_auth.PGUSER}}
DB_PASSWORD=${{Postgres_auth.PGPASSWORD}}
PORT=3001
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── product-service ──────────────────────────────────────────
DB_HOST=${{Postgres_products.PGHOST}}
DB_PORT=${{Postgres_products.PGPORT}}
DB_NAME=${{Postgres_products.PGDATABASE}}
DB_USER=${{Postgres_products.PGUSER}}
DB_PASSWORD=${{Postgres_products.PGPASSWORD}}
PORT=3002
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── order-service ────────────────────────────────────────────
DB_HOST=${{Postgres_orders.PGHOST}}
DB_PORT=${{Postgres_orders.PGPORT}}
DB_NAME=${{Postgres_orders.PGDATABASE}}
DB_USER=${{Postgres_orders.PGUSER}}
DB_PASSWORD=${{Postgres_orders.PGPASSWORD}}
PORT=3003
PRODUCT_SERVICE_URL=http://product-service.railway.internal:3002
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── cart-service ─────────────────────────────────────────────
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
CART_TTL_SECONDS=604800
PORT=3004
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── payment-service ──────────────────────────────────────────
DB_HOST=${{Postgres_payments.PGHOST}}
DB_PORT=${{Postgres_payments.PGPORT}}
DB_NAME=${{Postgres_payments.PGDATABASE}}
DB_USER=${{Postgres_payments.PGUSER}}
DB_PASSWORD=${{Postgres_payments.PGPASSWORD}}
PORT=3005
STRIPE_SECRET_KEY=sk_live_...        # from Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...      # from Stripe webhook settings
ORDER_SERVICE_URL=http://order-service.railway.internal:3003
NOTIFICATION_SERVICE_URL=http://notification-service.railway.internal:3006
RABBITMQ_URL=amqp://${{RabbitMQ.RABBITMQ_DEFAULT_USER}}:${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}@rabbitmq.railway.internal:5672
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── notification-service ─────────────────────────────────────
PORT=3006
SMTP_HOST=smtp.sendgrid.net          # or smtp.mailtrap.io for staging
SMTP_PORT=587
SMTP_USER=apikey                     # SendGrid: literal "apikey"
SMTP_PASS=SG.xxxx                    # SendGrid API key
EMAIL_FROM=noreply@yourdomain.com
RABBITMQ_URL=amqp://${{RabbitMQ.RABBITMQ_DEFAULT_USER}}:${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}@rabbitmq.railway.internal:5672
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app

# ── api-gateway (nginx) ──────────────────────────────────────
PORT=8080
AUTH_SERVICE_HOST=auth-service.railway.internal
AUTH_SERVICE_PORT=3001
PRODUCT_SERVICE_HOST=product-service.railway.internal
PRODUCT_SERVICE_PORT=3002
ORDER_SERVICE_HOST=order-service.railway.internal
ORDER_SERVICE_PORT=3003
CART_SERVICE_HOST=cart-service.railway.internal
CART_SERVICE_PORT=3004
PAYMENT_SERVICE_HOST=payment-service.railway.internal
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_HOST=notification-service.railway.internal
NOTIFICATION_SERVICE_PORT=3006

# ── frontend (set in Vercel dashboard, not Railway) ──────────
VITE_API_BASE_URL=https://api-gateway.up.railway.app/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...   # from Stripe dashboard

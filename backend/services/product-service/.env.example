# Product Service Environment Variables
PORT=3002
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_products
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# Same secret as auth-service — used to verify JWTs from the auth service
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_in_production

CORS_ORIGIN=http://localhost:5173

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

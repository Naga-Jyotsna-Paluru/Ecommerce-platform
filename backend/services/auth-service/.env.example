# Auth Service Environment Variables
# Copy this to .env and fill in real values — never commit .env

# Server
PORT=3001
NODE_ENV=development

# Database — PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_auth
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# JWT Secrets — use 64+ character random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
